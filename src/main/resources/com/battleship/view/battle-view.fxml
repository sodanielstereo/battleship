<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.battleship.controller.BattleController"
            stylesheets="@../styles/styles.css"
            styleClass="battle-root">
  <top>
    <VBox alignment="CENTER"
                      spacing="8"
                      styleClass="battle-header">
      <padding>
        <Insets top="18" right="20" bottom="12" left="20"/>
      </padding>
      <Label text="Batalla Naval"
                               styleClass="battle-title-label"/>
      <Label fx:id="playerInfoLabel"
                               text="Jugador y oponente"
                               styleClass="battle-info-label"/>
      <Label fx:id="phaseInfoLabel"
                               text="Fase actual"
                               styleClass="battle-info-label"/>
      <Label fx:id="statusLabel"
                               text="Estado"
                               styleClass="status-label"/>
    </VBox>
  </top>

  <center>
    <HBox alignment="CENTER"
                      spacing="40"
                      styleClass="boards-container">
      <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
      </padding>
      <VBox alignment="CENTER"
                              spacing="12"
                              styleClass="board-card">
        <Label text="Tu territorio"
                                       styleClass="board-title-label"/>
        <Label text="Tablero de posición"
                                       styleClass="normal-label"/>
        <GridPane fx:id="humanBoardGrid"
                                          alignment="CENTER"
                                          hgap="2"
                                          vgap="2"
                                          styleClass="board-grid"/>
      </VBox>
      <VBox alignment="CENTER"
                              spacing="12"
                              styleClass="board-card">
        <Label text="Territorio enemigo"
                                       styleClass="board-title-label"/>
        <Label text="Tablero principal"
                                       styleClass="normal-label"/>
        <GridPane fx:id="machineBoardGrid"
                                          alignment="CENTER"
                                          hgap="2"
                                          vgap="2"
                                          styleClass="board-grid"/>
      </VBox>
    </HBox>
  </center>

  <bottom>
    <HBox alignment="CENTER"
                      spacing="12"
                      styleClass="battle-footer">
      <padding>
        <Insets top="12" right="20" bottom="18" left="20"/>
      </padding>
      <Button text="Volver al inicio"
                                onAction="#onBackToStartClicked"
                                styleClass="secondary-button"/>
    </HBox>
  </bottom>
</BorderPane>
