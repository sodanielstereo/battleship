<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="battle-root" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.battleship.controller.BattleController">
  <top>
    <VBox alignment="CENTER" spacing="8" styleClass="battle-header">
      <padding>
        <Insets bottom="12" left="20" right="20" top="18" />
      </padding>
      <Label styleClass="battle-title-label" text="Batalla Naval" />
      <Label fx:id="playerInfoLabel" styleClass="battle-info-label" text="Jugador y oponente" />
      <Label fx:id="phaseInfoLabel" styleClass="battle-info-label" text="Fase actual" />
      <Label fx:id="statusLabel" styleClass="status-label" text="Estado" />
    </VBox>
  </top>

  <center>
    <HBox alignment="CENTER" spacing="40" styleClass="boards-container">
      <padding>
        <Insets bottom="24" left="24" right="24" top="24" />
      </padding>
      <VBox alignment="CENTER" spacing="12" styleClass="board-card">
        <Label styleClass="board-title-label" text="Tu territorio" />
        <Label styleClass="normal-label" text="Tablero de posición" />
        <GridPane fx:id="humanBoardGrid" alignment="CENTER" hgap="2" styleClass="board-grid" vgap="2" />
      </VBox>
      <VBox alignment="CENTER" spacing="12" styleClass="board-card">
        <Label styleClass="board-title-label" text="Territorio enemigo" />
        <Label styleClass="normal-label" text="Tablero principal" />
        <GridPane fx:id="machineBoardGrid" alignment="CENTER" hgap="2" styleClass="board-grid" vgap="2" />
      </VBox>
    </HBox>
  </center>

  <bottom>
    <HBox alignment="CENTER" prefHeight="83.0" prefWidth="463.0" spacing="12" styleClass="battle-footer">
      <padding>
        <Insets bottom="18" left="20" right="20" top="12" />
      </padding>
      <Button onAction="#onBackToStartClicked" styleClass="secondary-button" text="Volver al inicio" />
    </HBox>
  </bottom>
</BorderPane>
