<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.battleship.controller.MainController"
      alignment="CENTER"
      spacing="20"
      stylesheets="@../styles/styles.css">
  <padding>
    <Insets top="35" right="40" bottom="35" left="40"/>
  </padding>
  <Label text="Batalla Naval"
             styleClass="title-label"/>
  <Label text="Mini Proyecto 4 - Programación Orientada a Eventos"
             styleClass="subtitle-label"/>
  <VBox alignment="CENTER"
            spacing="12"
            styleClass="start-card">
    <Label text="Inicio de partida"
                   styleClass="section-title-label"/>
    <Label text="Ingresa tu nickname para crear una nueva partida."
                   styleClass="normal-label"/>
    <TextField fx:id="nicknameTextField"
                       promptText="Ejemplo: Daniel"
                       maxWidth="280"
                       styleClass="nickname-field"/>
    <HBox alignment="CENTER"
                  spacing="12">
      <Button fx:id="newGameButton"
                          text="Nueva partida"
                          onAction="#onNewGameClicked"
                          styleClass="primary-button"/>
      <Button fx:id="loadGameButton"
                          text="Cargar partida"
                          onAction="#onLoadGameClicked"
                          styleClass="secondary-button"/>
    </HBox>
    <Region prefHeight="8"/>
    <Label fx:id="statusLabel"
                   text="Estado inicial"
                   wrapText="true"
                   styleClass="status-label"/>
    <Label fx:id="gameInfoLabel"
                   text="Información de la partida"
                   wrapText="true"
                   styleClass="game-info-label"/>
  </VBox>
</VBox>
