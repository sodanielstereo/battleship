<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.battleship.controller.MainController"
      alignment="CENTER"
      spacing="24"
      prefWidth="900"
      prefHeight="600"
      stylesheets="@../styles/styles.css"
      styleClass="main-root">
  <padding>
    <Insets top="40" right="40" bottom="40" left="40"/>
  </padding>
  <VBox alignment="CENTER"
                spacing="18"
                maxWidth="520"
                styleClass="start-card">
    <Label text="Batalla Naval"
                           styleClass="title-label"/>
    <VBox alignment="CENTER"
                          spacing="10">
      <Label text="Inicio de partida"
                                     styleClass="board-title-label"/>
      <Button text="Instrucciones"
              onAction="#onInstructionsClicked"
              minWidth="190"
              styleClass="instructions-button"/>
      <Label text="Ingresa tu nickname para crear una nueva partida."
                                     styleClass="normal-label"/>
      <TextField fx:id="nicknameTextField"
                                         promptText="Nickname"
                                         maxWidth="320"/>
    </VBox>
    <HBox alignment="CENTER"
                          spacing="14">
      <Button fx:id="newGameButton"
                                      text="Nueva partida"
                                      onAction="#onNewGameClicked"
                                      minWidth="170"
                                      styleClass="primary-button"/>
      <Button fx:id="loadGameButton"
                                      text="Cargar partida"
                                      onAction="#onLoadGameClicked"
                                      minWidth="170"
                                      styleClass="secondary-button"/>
    </HBox>
    <VBox alignment="CENTER"
                          spacing="8">
      <Label fx:id="statusLabel"
                                     text="Ingresa tu nickname para iniciar una nueva partida."
                                     wrapText="true"
                                     styleClass="status-label"/>
      <Label fx:id="gameInfoLabel"
                                     text="No hay partida guardada todavía."
                                     wrapText="true"
                                     styleClass="game-info-label"/>
    </VBox>
  </VBox>
</VBox>
